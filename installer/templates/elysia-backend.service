[Unit]
Description=Elysia Panel - Backend (NestJS)
After=network.target docker.service
Wants=docker.service
# Note: volontairement PAS de dépendance sur pteroq.service ou wings.service
# Elysia est indépendant de Pterodactyl.

[Service]
Type=simple
User=elysia
Group=elysia
WorkingDirectory=/opt/elysia/backend
EnvironmentFile=/etc/elysia/backend.env
ExecStart=/usr/bin/node dist/src/main.js
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
