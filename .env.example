# =============================================================================
# ELYSIA PANEL — Environment configuration (development / reference)
# =============================================================================
# Ports are deliberately chosen to NEVER collide with a Pterodactyl + Wings
# install on the same host:
#   Pterodactyl panel nginx : 80 / 443
#   Wings daemon            : 8080 (API), 2022 (SFTP)
#   Wings docker network    : pterodactyl_nw (172.18.0.0/16 by default)
# Elysia uses a completely different range below.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ELYSIA_ENV=development
ELYSIA_APP_NAME="Elysia Panel"
ELYSIA_DOMAIN=elysia.local
ELYSIA_DATA_DIR=/var/lib/elysia
ELYSIA_CONFIG_DIR=/etc/elysia
ELYSIA_LOG_DIR=/var/log/elysia
ELYSIA_RUNTIME_DIR=/srv/elysia

# ---------------------------------------------------------------------------
# Dashboard (Next.js)
# ---------------------------------------------------------------------------
DASHBOARD_PORT=9400
DASHBOARD_URL=http://localhost:9400

# ---------------------------------------------------------------------------
# Backend API (NestJS) — REST + WebSocket gateway
# ---------------------------------------------------------------------------
BACKEND_HTTP_PORT=9401
BACKEND_WS_PORT=9402
BACKEND_GRPC_PORT=9403          # backend <-> elysia-node internal gRPC
BACKEND_JWT_SECRET=change_me_in_production
BACKEND_JWT_REFRESH_SECRET=change_me_in_production
BACKEND_JWT_ACCESS_TTL=15m
BACKEND_JWT_REFRESH_TTL=30d

# ---------------------------------------------------------------------------
# Elysia Node (Go daemon) — one instance per hosting node
# ---------------------------------------------------------------------------
NODE_API_PORT=9500              # local REST for node self-management
NODE_GRPC_PORT=9501             # gRPC server, called by backend
NODE_WS_PORT=9502               # console / stats streaming
NODE_SFTP_PORT=9522             # per-node SFTP (distinct from Wings' 2022)
NODE_MTLS_CERT=/etc/elysia/certs/node.crt
NODE_MTLS_KEY=/etc/elysia/certs/node.key
NODE_MTLS_CA=/etc/elysia/certs/ca.crt

# ---------------------------------------------------------------------------
# PostgreSQL (own instance — never shares Pterodactyl's DB or user)
# ---------------------------------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=elysia
POSTGRES_USER=elysia
POSTGRES_PASSWORD=change_me_in_production

# ---------------------------------------------------------------------------
# Redis (own instance — separate from any Pterodactyl/Wings cache)
# ---------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=63790
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0

# ---------------------------------------------------------------------------
# nginx (Elysia's own reverse proxy, separate vhost/process from Ptero's)
# ---------------------------------------------------------------------------
NGINX_HTTP_PORT=9080
NGINX_HTTPS_PORT=9443

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
DOCKER_NETWORK_NAME=elysia-net
DOCKER_NETWORK_SUBNET=172.30.0.0/16   # distinct from pterodactyl_nw (172.18.0.0/16)
DOCKER_COMPOSE_PROJECT_NAME=elysia
DOCKER_CONTAINER_PREFIX=elysia_
DOCKER_LABEL_NAMESPACE=io.elysia

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9490
GRAFANA_PORT=9491

# ---------------------------------------------------------------------------
# OAuth2 / OIDC providers (optional)
# ---------------------------------------------------------------------------
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Object storage for backups (S3-compatible: AWS S3, R2, B2, MinIO)
# ---------------------------------------------------------------------------
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=auto
